# ── Financial News Intelligence System ─ Environment Variables ──────────────
# Copy this file to .env and fill in your real secrets.
# NEVER commit .env to source control.

# NewsAPI.org free key: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# GitHub Personal Access Token — authenticates with Azure AI inference
# Generate: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your_github_token_here

# Gmail address used to SEND the report
GMAIL_ADDRESS=your_email@gmail.com

# Gmail App Password (recommended) or account password (if less secure apps is enabled)
GMAIL_PASSWORD=your_app_password_here

# Scheduled send time (24h format, local system time)
REPORT_TIME=06:30

# Institutional Macro & Earnings Data
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
# Finnhub: https://finnhub.io/dashboard
FRED_API_KEY=your_fred_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Distribution List
# Comma-separated list of emails to receive the report
RECIPIENTS=recipient1@example.com,recipient2@example.com
